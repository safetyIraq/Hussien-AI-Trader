<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#050505"
    android:padding="12dp">

    <LinearLayout
        android:id="@+id/header_stats"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#111111"
        android:orientation="horizontal"
        android:padding="15dp"
        android:weightSum="2">

        <TextView
            android:id="@+id/txtBullScore"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="BULL: 0%"
            android:textColor="#00FF00"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtBearScore"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="BEAR: 0%"
            android:textColor="#FF0000"
            android:gravity="end"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/ai_terminal"
        android:layout_width="match_parent"
        android:layout_height="250dp"
        android:layout_below="@id/header_stats"
        android:layout_marginTop="10dp"
        android:background="#000000"
        android:fontFamily="monospace"
        android:padding="10dp"
        android:text="> INITIALIZING SHADOW ENGINE...\n> WAITING FOR USER COMMAND..."
        android:textColor="#00FF41"
        android:textSize="12sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="vertical"
        android:paddingBottom="10dp">

        <Button
            android:id="@+id/btnBuy"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:backgroundTint="#1B5E20"
            android:text="SNIPER BUY (فتح صفقة شراء)"
            android:textColor="#FFFFFF"
            android:textSize="16sp" />

        <Button
            android:id="@+id/btnSell"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:layout_marginTop="10dp"
            android:backgroundTint="#B71C1C"
            android:text="SNIPER SELL (فتح صفقة بيع)"
            android:textColor="#FFFFFF"
            android:textSize="16sp" />
    </LinearLayout>
</RelativeLayout>
