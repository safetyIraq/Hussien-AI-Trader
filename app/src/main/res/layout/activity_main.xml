<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0A"
    android:padding="15dp">

    <LinearLayout
        android:id="@+id/scoreBoard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="2"
        android:background="#1A1A1A"
        android:padding="10dp">
        
        <TextView
            android:id="@+id/bullScoreTxt"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="BULL: 0%"
            android:textColor="#00FF00"
            android:textStyle="bold" />
            
        <TextView
            android:id="@+id/bearScoreTxt"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="BEAR: 0%"
            android:textColor="#FF0000"
            android:gravity="end"
            android:textStyle="bold" />
    </LinearLayout>

    <ScrollView
        android:id="@+id/aiConsole"
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:layout_below="@id/scoreBoard"
        android:layout_marginTop="10dp"
        android:background="#000000"
        android:padding="8dp">
        <TextView
            android:id="@+id/aiAnalysisOutput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="> INITIALIZING DEEPSEEK ANALYST..."
            android:textColor="#00FF41"
            android:fontFamily="monospace"
            android:textSize="12sp" />
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="vertical">

        <Button
            android:id="@+id/btnSniperBuy"
            android:layout_width="match_parent"
            android:layout_height="65dp"
            android:backgroundTint="#004D40"
            android:text="SNIPER BUY 🚀"
            android:textSize="18sp" />

        <Button
            android:id="@+id/btnSniperSell"
            android:layout_width="match_parent"
            android:layout_height="65dp"
            android:layout_marginTop="8dp"
            android:backgroundTint="#B71C1C"
            android:text="SNIPER SELL 📉"
            android:textSize="18sp" />
            
        <Button
            android:id="@+id/btnCloseAll"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="8dp"
            android:backgroundTint="#37474F"
            android:text="CLOSE ALL POSITIONS" />
    </LinearLayout>

</RelativeLayout>
