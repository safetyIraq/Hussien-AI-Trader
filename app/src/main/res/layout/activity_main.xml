<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000"
    android:padding="20dp">

    <TextView
        android:id="@+id/txtBull"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="BULL: 0%"
        android:textColor="#00FF00"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/txtBear"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="BEAR: 0%"
        android:textColor="#FF0000"
        android:textSize="22sp"
        android:textStyle="bold" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="20dp"
        android:background="#111111">
        <TextView
            android:id="@+id/ai_console"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="10dp"
            android:text="> INITIALIZING SHADOW ENGINE..."
            android:textColor="#00FF41"
            android:fontFamily="monospace" />
    </ScrollView>

    <Button
        android:id="@+id/btnBuy"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_marginTop="10dp"
        android:backgroundTint="#1B5E20"
        android:text="SNIPER BUY" />

    <Button
        android:id="@+id/btnSell"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_marginTop="5dp"
        android:backgroundTint="#B71C1C"
        android:text="SNIPER SELL" />

</LinearLayout>
